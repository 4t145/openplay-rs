; Engine configuration file.
; It's best edited using the editor UI.

config_version=5

[application]

config/name="OpenPlay"
run/main_scene="res://scenes/GameRoom.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[display]

window/size/viewport_width=960
window/size/viewport_height=540

[rendering]

renderer/rendering_method="gl_compatibility"

[gdextension]

; Ensure the extension is loaded by the editor/runtime
openplay_sdk="res://addons/openplay_sdk/openplay_sdk.gdextension"
